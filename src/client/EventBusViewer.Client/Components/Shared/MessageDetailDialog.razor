@using System.Text.Json
@using Azure.Messaging.ServiceBus

<MudDialog>
    <DialogContent>
        <MudStack Spacing="4">

            @* ── Metadata table ── *@
            <MudText Typo="Typo.subtitle2" Color="Color.Primary">Message Properties</MudText>
            <MudSimpleTable Dense="true" Hover="true" Style="background: transparent;">
                <tbody>
                    <tr>
                        <td style="width:170px"><MudText Typo="Typo.body2" Color="Color.Secondary">Message ID</MudText></td>
                        <td><MudText Typo="Typo.body2" Style="font-family: monospace;">@Message.MessageId</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">Correlation ID</MudText></td>
                        <td><MudText Typo="Typo.body2" Style="font-family: monospace;">@(Message.CorrelationId ?? "—")</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">Content Type</MudText></td>
                        <td><MudText Typo="Typo.body2">@(Message.ContentType ?? "—")</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">Enqueued</MudText></td>
                        <td><MudText Typo="Typo.body2">@Message.EnqueuedTime.ToString("yyyy-MM-dd HH:mm:ss zzz")</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">Sequence #</MudText></td>
                        <td><MudText Typo="Typo.body2">@Message.SequenceNumber</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">Delivery Count</MudText></td>
                        <td><MudText Typo="Typo.body2">@Message.DeliveryCount</MudText></td>
                    </tr>
                </tbody>
            </MudSimpleTable>

            @* ── Dead-letter info ── *@
            @if (IsDeadLetter)
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Error">Dead-letter Details</MudText>
                <MudSimpleTable Dense="true" Hover="true" Style="background: transparent;">
                    <tbody>
                        <tr>
                            <td style="width:170px"><MudText Typo="Typo.body2" Color="Color.Error">DL Reason</MudText></td>
                            <td><MudText Typo="Typo.body2">@(Message.DeadLetterReason ?? "—")</MudText></td>
                        </tr>
                        <tr>
                            <td><MudText Typo="Typo.body2" Color="Color.Error">DL Description</MudText></td>
                            <td><MudText Typo="Typo.body2">@(Message.DeadLetterErrorDescription ?? "—")</MudText></td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            }

            @* ── Application Properties ── *@
            @if (Message.ApplicationProperties.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Primary">Application Properties</MudText>
                <MudSimpleTable Dense="true" Hover="true" Style="background: transparent;">
                    <tbody>
                        @foreach (KeyValuePair<string, object> prop in Message.ApplicationProperties)
                        {
                            <tr>
                                <td style="width:170px"><MudText Typo="Typo.body2" Color="Color.Secondary">@prop.Key</MudText></td>
                                <td><MudText Typo="Typo.body2" Style="font-family: monospace;">@(prop.Value?.ToString() ?? "null")</MudText></td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }

            @* ── Body ── *@
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.subtitle2" Color="Color.Primary">Body</MudText>
                <MudSpacer/>
                <MudTooltip Text="Copy body to clipboard">
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="CopyBody"/>
                </MudTooltip>
            </MudStack>
            <MudPaper Class="pa-4" Elevation="0" Style="background: var(--mud-palette-surface); border-radius: 6px; overflow: auto; max-height: 400px;">
                <pre style="margin:0; white-space:pre-wrap; word-break:break-word; font-size:0.85rem; font-family:'Cascadia Code','Fira Code','Consolas',monospace; color: var(--mud-palette-text-primary);">@FormatBody()</pre>
            </MudPaper>

        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Text">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired] public ServiceBusReceivedMessage Message { get; set; } = null!;
    [Parameter] public bool IsDeadLetter { get; set; }

    [Inject] private IJSRuntime Js { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private string FormatBody()
    {
        string raw = Message.Body?.ToString() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(raw))
            return "(empty)";

        try
        {
            using JsonDocument doc = JsonDocument.Parse(raw);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return raw;
        }
    }

    private async Task CopyBody()
    {
        try
        {
            await Js.InvokeVoidAsync("navigator.clipboard.writeText", FormatBody());
            Snackbar.Add("Copied to clipboard", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to copy", Severity.Error);
        }
    }

    private void Close() => MudDialog.Close();
}

