@using BusWorks.Viewer.Services
@inject QueueService QueueService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"/>
            <MudText Typo="Typo.h6">Create Queue</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @* ── Loading bar — visible as soon as the button is clicked ── *@
        @if (_creating)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2"/>
        }
        <MudForm @ref="_form" @bind-IsValid="_formValid">
            <MudStack Spacing="4">

                @* ── Name ── *@
                <MudTextField T="string"
                              @bind-Value="_name"
                              Label="Queue Name"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Queue name is required."
                              Placeholder="e.g. orders.created"
                              Immediate="true"
                              Disabled="_creating"
                              Error="@(_nameError is not null)"
                              ErrorText="@_nameError"
                              OnBlur="@(_ => _nameError = null)"/>

                <MudDivider/>

                @* ── Numeric settings ── *@
                <MudNumericField T="int"
                                 @bind-Value="_maxDeliveryCount"
                                 Label="Max Delivery Count"
                                 Variant="Variant.Outlined"
                                 Min="1"
                                 Required="true"
                                 Disabled="_creating"
                                 HelperText="How many times delivery is attempted before the message is dead-lettered."/>

                <MudNumericField T="int"
                                 @bind-Value="_lockDurationSeconds"
                                 Label="Lock Duration (seconds)"
                                 Variant="Variant.Outlined"
                                 Min="1"
                                 Max="300"
                                 Required="true"
                                 Disabled="_creating"
                                 HelperText="How long a received message stays locked (1 – 300 s)."/>

                <MudDivider/>

                @* ── Toggles ── *@
                <MudSwitch T="bool"
                           @bind-Value="_requiresSession"
                           Label="Requires Session"
                           Color="Color.Primary"
                           Disabled="_creating"/>

                <MudSwitch T="bool"
                           @bind-Value="_deadLetterOnExpiry"
                           Label="Dead-letter on Message Expiry"
                           Color="Color.Primary"
                           Disabled="_creating"/>

            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Variant="Variant.Text"
                   Disabled="_creating">
            Cancel
        </MudButton>
        <MudButton OnClick="CreateAsync"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@(_creating ? null : Icons.Material.Filled.AddCircle)"
                   ButtonType="ButtonType.Button"
                   Disabled="@(_creating || !_formValid)">
            @if (_creating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                <span>Creating…</span>
            }
            else
            {
                <span>Create</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = null!;
    private bool _formValid = true;

    private string? _name;
    private string? _nameError;
    private int _maxDeliveryCount = 10;
    private int _lockDurationSeconds = 60;
    private bool _requiresSession;
    private bool _deadLetterOnExpiry;
    private bool _creating;

    private async Task CreateAsync()
    {
        // Disable everything immediately — prevents double-submit and shows feedback at once
        _creating = true;
        try
        {
            await _form.ValidateAsync();
            if (!_formValid) return;

            _nameError = null;
            bool exists = await QueueService.QueueExistsAsync(_name!);
            if (exists)
            {
                _nameError = $"A queue named \"{_name}\" already exists.";
                return;
            }

            await QueueService.CreateQueueAsync(
                _name!,
                _requiresSession,
                _maxDeliveryCount,
                _lockDurationSeconds,
                _deadLetterOnExpiry);

            Snackbar.Add($"Queue \"{_name}\" created successfully.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create queue: {ex.Message}", Severity.Error);
        }
        finally
        {
            _creating = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
