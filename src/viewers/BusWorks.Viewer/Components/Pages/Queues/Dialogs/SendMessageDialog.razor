@using System.Text.Json
@using BusWorks.Viewer.Services
@inject QueueService QueueService
@inject ISnackbar Snackbar
<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Send" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Send Message</MudText>
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@QueueName</MudChip>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="4">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Paste or type a valid JSON message body below. The message will be sent with
                <code>ContentType: application/json</code> and a generated <code>MessageId</code>.
            </MudText>
            @if (RequiresSession)
            {
                <MudTextField T="string"
                              @bind-Value="_sessionId"
                              Label="Session ID"
                              Placeholder="my-session-id"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Immediate="true"
                              Required="true"
                              RequiredError="Session ID is required for session-enabled queues."
                              Disabled="_sending"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Tag"
                              HelperText="This queue requires sessions. Every message must carry a Session ID." />
            }
            <MudTextField T="string"
                          Value="@_jsonInput"
                          ValueChanged="@((string? v) => OnJsonChanged(v))"
                          Label="Message Body (JSON)"
                          Placeholder="{&quot;key&quot;: &quot;value&quot;}"
                          Lines="10"
                          MaxLines="20"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Immediate="true"
                          Style="font-family:'Cascadia Code','Fira Code','Consolas',monospace; font-size:0.875rem;"
                          Error="_validationError is not null"
                          ErrorText="@_validationError"
                          Disabled="_sending" />
            @if (_formattedPreview is not null && _validationError is null)
            {
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Preview (formatted)</MudText>
                    <MudPaper Class="pa-3" Elevation="0"
                              Style="background: var(--mud-palette-surface); border-radius: 6px; overflow: auto; max-height: 260px; border: 1px solid var(--mud-palette-divider);">
                        <pre
                            style="margin:0; white-space:pre-wrap; word-break:break-word; font-size:0.82rem; font-family:'Cascadia Code','Fira Code','Consolas',monospace; color: var(--mud-palette-text-primary);">@_formattedPreview</pre>
                    </MudPaper>
                </MudStack>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Disabled="_sending">Cancel</MudButton>
        <MudButton OnClick="SendAsync"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@(_sending ? null : Icons.Material.Filled.Send)"
                   Disabled="@(!CanSend)"
                   ButtonType="ButtonType.Button">
            @if (_sending)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Sending&#x2026;</span>
            }
            else
            {
                <span>Send</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter, EditorRequired] public string QueueName { get; set; } = string.Empty;

    /// <summary>When true a Session ID field is shown and must be filled before sending.</summary>
    [Parameter]
    public bool RequiresSession { get; set; }

    private string? _jsonInput;
    private string? _formattedPreview;
    private string? _validationError;
    private string? _sessionId;
    private bool _sending;
    private bool CanSend =>
        !_sending &&
        !string.IsNullOrWhiteSpace(_jsonInput) &&
        _validationError is null &&
        (!RequiresSession || !string.IsNullOrWhiteSpace(_sessionId));

    private void OnJsonChanged(string? value)
    {
        _jsonInput = string.IsNullOrEmpty(value) ? null : value;
        ValidateJson();
    }

    private void ValidateJson()
    {
        _formattedPreview = null;
        _validationError = null;
        if (string.IsNullOrWhiteSpace(_jsonInput))
            return;
        try
        {
            using var doc = JsonDocument.Parse(_jsonInput);
            _formattedPreview = JsonSerializer.Serialize(doc.RootElement,
                new JsonSerializerOptions { WriteIndented = true });
        }
        catch (JsonException ex)
        {
            _validationError = $"Invalid JSON: {ex.Message}";
        }
    }

    private async Task SendAsync()
    {
        ValidateJson();
        if (!CanSend || _jsonInput is null)
            return;
        _sending = true;
        try
        {
            await QueueService.SendMessageAsync(QueueName, _jsonInput, RequiresSession ? _sessionId : null);
            Snackbar.Add($"Message sent to \"{QueueName}\".", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to send message: {ex.Message}", Severity.Error);
        }
        finally
        {
            _sending = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
