@page "/queues/overview"
@using Azure.Messaging.ServiceBus.Administration
@using BusWorks.Viewer.Models
@using BusWorks.Viewer.Services
@inject QueueService QueueService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Queues Overview</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Queues Overview</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.AddCircle"
               OnClick="OpenCreateDialogAsync"
               Disabled="_loading">
        New Queue
    </MudButton>
    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                   Color="Color.Primary"
                   OnClick="LoadQueuesAsync"
                   Disabled="_loading"
                   title="Refresh queues" />
</MudStack>


<MudText Typo="Typo.body1" Class="mb-6" Color="Color.Secondary">
    Monitor and inspect all active queues on the event bus.
</MudText>

@* ── Summary cards ── *@
<MudGrid Spacing="4">
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.Queue" Color="Color.Primary" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Queues</MudText>
                    <MudText Typo="Typo.h5">@_queues.Count</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.Message" Color="Color.Info" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Messages</MudText>
                    <MudText Typo="Typo.h5">@FormatCount(_queues.Sum(q => q.TotalMessages))</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Active Messages</MudText>
                    <MudText Typo="Typo.h5">@FormatCount(_queues.Sum(q => q.ActiveMessages))</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Dead-letter Messages</MudText>
                    <MudText Typo="Typo.h5">@FormatCount(_queues.Sum(q => q.DeadLetterMessages))</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@* ── Error alert ── *@
@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-6" ShowCloseIcon="true"
              CloseIconClicked="() => _error = null">
        @_error
    </MudAlert>
}

@* ── Queue table ── *@
<MudTable Items="@_queues"
          Hover="true"
          Striped="true"
          Elevation="2"
          Class="mt-6"
          Loading="_loading"
          LoadingProgressColor="Color.Primary"
          Filter="FilterFunc"
          Dense="true"
          T="QueueInfo">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Queues</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="_searchTerm"
                      Placeholder="Search by name…"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Immediate="true"
                      Class="mt-0" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<QueueInfo, object>(x => x.Name)">Name</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<QueueInfo, object>(x => x.Status.ToString())">Status</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<QueueInfo, object>(x => x.RequiresSession)">Session</MudTableSortLabel>
        </MudTh>
        <MudTh Style="text-align:right">
            <MudTableSortLabel SortBy="new Func<QueueInfo, object>(x => x.ActiveMessages)">Active</MudTableSortLabel>
        </MudTh>
        <MudTh Style="text-align:right">
            <MudTableSortLabel SortBy="new Func<QueueInfo, object>(x => x.DeadLetterMessages)">Dead-letter
            </MudTableSortLabel>
        </MudTh>
        <MudTh Style="text-align:right">
            <MudTableSortLabel SortBy="new Func<QueueInfo, object>(x => x.TotalMessages)">Total</MudTableSortLabel>
        </MudTh>
        <MudTh Style="width:50px"></MudTh>
        <MudTh Style="width:50px"></MudTh>
        <MudTh Style="width:50px"></MudTh>
        <MudTh Style="width:50px"></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Queue"
                       Size="Size.Small"
                       Href="@($"/queues/{Uri.EscapeDataString(context.Name)}")">
                @context.Name
            </MudButton>
        </MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string"
                     Color="@StatusColor(context.Status)"
                     Size="Size.Small"
                     Variant="Variant.Filled">
                @context.Status.ToString()
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Session">
            @if (context.RequiresSession)
            {
                <MudTooltip Text="Sessions required">
                    <MudChip T="string"
                             Color="Color.Tertiary"
                             Size="Size.Small"
                             Variant="Variant.Outlined"
                             Icon="@Icons.Material.Filled.AccountTree">
                        Session
                    </MudChip>
                </MudTooltip>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Default">—</MudText>
            }
        </MudTd>
        <MudTd DataLabel="Active" Style="text-align:right">
            <MudChip T="string" Color="Color.Success" Size="Size.Small"
                     Variant="Variant.Text">@FormatCount(context.ActiveMessages)</MudChip>
        </MudTd>
        <MudTd DataLabel="Dead-letter" Style="text-align:right">
            @if (context.DeadLetterMessages > 0)
            {
                <MudChip T="string" Color="Color.Error" Size="Size.Small"
                         Variant="Variant.Text">@FormatCount(context.DeadLetterMessages)</MudChip>
            }
            else
            {
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Text">0</MudChip>
            }
        </MudTd>
        <MudTd DataLabel="Total" Style="text-align:right">
            <MudChip T="string" Color="Color.Info" Size="Size.Small"
                     Variant="Variant.Text">@FormatCount(context.TotalMessages)</MudChip>
        </MudTd>
        <MudTd Style="text-align:right">
            <MudTooltip Text="Send message to queue">
                <MudIconButton Icon="@Icons.Material.Filled.Send"
                               Size="Size.Small"
                               Color="Color.Secondary"
                               title="Send message"
                               OnClick="@(() => OpenSendDialogAsync(context))" />
            </MudTooltip>
        </MudTd>
        <MudTd Style="text-align:right">
            <MudTooltip Text="Edit queue settings">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Size="Size.Small"
                               Color="Color.Primary"
                               title="Edit queue"
                               OnClick="@(() => OpenUpdateDialogAsync(context.Name))" />
            </MudTooltip>
        </MudTd>
        <MudTd Style="text-align:right">
            <MudTooltip Text="Delete queue">
                <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                               Size="Size.Small"
                               Color="Color.Error"
                               title="Delete queue"
                               OnClick="@(() => OpenDeleteDialogAsync(context.Name))" />
            </MudTooltip>
        </MudTd>
        <MudTd Style="text-align:right">
            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                           Size="Size.Small"
                           Color="Color.Primary"
                           title="View queue details"
                           Href="@($"/queues/{Uri.EscapeDataString(context.Name)}")" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body1" Color="Color.Secondary">No queues found.</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private bool _loading;
    private string? _error;
    private string? _searchTerm;
    private List<QueueInfo> _queues = [];

    protected override Task OnInitializedAsync() => LoadQueuesAsync();

    private async Task LoadQueuesAsync()
    {
        _loading = true;
        StateHasChanged(); // flush the loading state before the fetch so the table indicator appears immediately
        _error = null;

        try
        {
            IReadOnlyList<QueueInfo> result = await QueueService.GetAllQueuesAsync();
            _queues = result.ToList();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load queues: {ex.Message}";
            Snackbar.Add(_error, Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Opens the create-queue dialog and refreshes the list on success.
    /// </summary>
    private async Task OpenCreateDialogAsync()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true,
            CloseButton = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<CreateQueueDialog>("", options);

        DialogResult? result = await dialog.Result;
        if (result is { Canceled: false })
            await LoadQueuesAsync();
    }

    /// <summary>
    /// Opens the update-queue dialog and refreshes the list on success.
    /// </summary>
    private async Task OpenUpdateDialogAsync(string queueName)
    {
        var parameters = new DialogParameters<UpdateQueueDialog>
        {
            { x => x.QueueName, queueName }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true,
            CloseButton = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<UpdateQueueDialog>(
            "", parameters, options);

        DialogResult? result = await dialog.Result;
        if (result is { Canceled: false })
            await LoadQueuesAsync();
    }

    /// <summary>
    /// Opens the delete-queue confirmation dialog and refreshes the list on success.
    /// </summary>
    private async Task OpenDeleteDialogAsync(string queueName)
    {
        var parameters = new DialogParameters<DeleteQueueDialog>
        {
            { x => x.QueueName, queueName }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
            CloseOnEscapeKey = true,
            CloseButton = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<DeleteQueueDialog>(
            "Confirm Deletion", parameters, options);

        DialogResult? result = await dialog.Result;
        if (result is { Canceled: false })
            await LoadQueuesAsync();
    }

    /// <summary>
    /// Opens the send-message dialog for the given queue.
    /// </summary>
    private async Task OpenSendDialogAsync(QueueInfo queue)
    {
        var parameters = new DialogParameters<SendMessageDialog>
        {
            { x => x.QueueName, queue.Name },
            { x => x.RequiresSession, queue.RequiresSession }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true,
            CloseButton = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<SendMessageDialog>(
            $"Send Message — {queue.Name}", parameters, options);

        DialogResult? result = await dialog.Result;
        if (result is { Canceled: false })
            await LoadQueuesAsync();
    }

    /// <summary>
    /// Client-side filter for the search text field.
    /// </summary>
    private bool FilterFunc(QueueInfo queue) =>
        string.IsNullOrWhiteSpace(_searchTerm)
        || queue.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase);

    /// <summary>
    /// Peek caps at 250 — show "250+" when we hit the cap.
    /// </summary>
    private static string FormatCount(int count) => count >= 250 ? "250+" : count.ToString();

    private static Color StatusColor(EntityStatus status)
    {
        if (status == EntityStatus.Active) return Color.Success;
        if (status == EntityStatus.Disabled) return Color.Error;
        if (status == EntityStatus.SendDisabled) return Color.Warning;
        if (status == EntityStatus.ReceiveDisabled) return Color.Warning;
        return Color.Default;
    }

}
