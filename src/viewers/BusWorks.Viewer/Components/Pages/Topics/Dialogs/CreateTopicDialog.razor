@using BusWorks.Viewer.Services
@inject TopicService TopicService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"/>
            <MudText Typo="Typo.h6">Create Topic</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @* ── Loading bar — visible as soon as the button is clicked ── *@
        @if (_creating)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2"/>
        }
        <MudForm @ref="_form" @bind-IsValid="_formValid">
            <MudStack Spacing="4">

                @* ── Name ── *@
                <MudTextField T="string"
                              @bind-Value="_name"
                              Label="Topic Name"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Topic name is required."
                              Placeholder="e.g. orders.events"
                              Immediate="true"
                              Disabled="_creating"
                              Error="@(_nameError is not null)"
                              ErrorText="@_nameError"
                              OnBlur="@(_ => _nameError = null)"/>

                <MudDivider/>

                @* ── TTL ── *@
                <MudNumericField T="int"
                                 @bind-Value="_defaultMessageTtlSeconds"
                                 Label="Default Message TTL (seconds)"
                                 Variant="Variant.Outlined"
                                 Min="1"
                                 Max="3600"
                                 Required="true"
                                 Disabled="_creating"
                                 HelperText="How long a message is retained if not consumed (1 – 3 600 s / up to 1 hour). Emulator limit."/>

                <MudDivider/>

                @* ── Toggles ── *@
                <MudSwitch T="bool"
                           @bind-Value="_enableBatchedOperations"
                           Label="Enable Batched Operations"
                           Color="Color.Primary"
                           Disabled="_creating"/>

            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Variant="Variant.Text"
                   Disabled="_creating">
            Cancel
        </MudButton>
        <MudButton OnClick="CreateAsync"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@(_creating ? null : Icons.Material.Filled.AddCircle)"
                   ButtonType="ButtonType.Button"
                   Disabled="@(_creating || !_formValid)">
            @if (_creating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                <span>Creating…</span>
            }
            else
            {
                <span>Create</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = null!;
    private bool _formValid = true;

    private string? _name;
    private string? _nameError;
    private int _defaultMessageTtlSeconds = 3600;
    private bool _enableBatchedOperations = true;
    private bool _creating;

    private async Task CreateAsync()
    {
        _creating = true;
        try
        {
            await _form.ValidateAsync();
            if (!_formValid) return;

            _nameError = null;
            bool exists = await TopicService.TopicExistsAsync(_name!);
            if (exists)
            {
                _nameError = $"A topic named \"{_name}\" already exists.";
                return;
            }

            await TopicService.CreateTopicAsync(
                _name!,
                _defaultMessageTtlSeconds,
                _enableBatchedOperations);

            Snackbar.Add($"Topic \"{_name}\" created successfully.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create topic: {ex.Message}", Severity.Error);
        }
        finally
        {
            _creating = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}

