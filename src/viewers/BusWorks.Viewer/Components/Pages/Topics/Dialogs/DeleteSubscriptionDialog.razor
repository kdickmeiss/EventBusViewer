@using BusWorks.Viewer.Services
@inject TopicService TopicService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Error"/>
            <MudText Typo="Typo.h6">Delete Subscription</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_deleting)
        {
            <MudProgressLinear Color="Color.Error" Indeterminate="true" Class="mb-4"/>
        }

        <MudStack Spacing="3">
            <MudText Typo="Typo.body1">
                Are you sure you want to delete subscription
                <strong>@SubscriptionName</strong> from topic <strong>@TopicName</strong>?
            </MudText>

            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                This action is <strong>irreversible</strong>. The subscription and all its messages will be permanently deleted.
            </MudAlert>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Variant="Variant.Text"
                   Disabled="_deleting">
            Cancel
        </MudButton>
        <MudButton OnClick="DeleteAsync"
                   Variant="Variant.Filled"
                   Color="Color.Error"
                   StartIcon="@(_deleting ? null : Icons.Material.Filled.DeleteForever)"
                   ButtonType="ButtonType.Button"
                   Disabled="_deleting">
            @if (_deleting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                <span>Deleting…</span>
            }
            else
            {
                <span>Delete</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired] public string TopicName        { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string SubscriptionName { get; set; } = string.Empty;

    private bool _deleting;

    private async Task DeleteAsync()
    {
        _deleting = true;
        try
        {
            await TopicService.DeleteSubscriptionAsync(TopicName, SubscriptionName);
            Snackbar.Add($"Subscription \"{SubscriptionName}\" deleted.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete subscription: {ex.Message}", Severity.Error);
        }
        finally
        {
            _deleting = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}

