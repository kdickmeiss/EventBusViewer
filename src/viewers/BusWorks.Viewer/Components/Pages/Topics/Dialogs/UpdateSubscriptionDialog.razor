@using Azure.Messaging.ServiceBus.Administration
@using BusWorks.Viewer.Services
@inject TopicService TopicService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Edit Subscription</MudText>
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                @TopicName / @SubscriptionName
            </MudChip>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_loading || _saving)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
        }

        @if (_loadError is not null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_loadError</MudAlert>
        }
        else if (_props is not null)
        {
            <MudForm @ref="_form" @bind-IsValid="_formValid">
                <MudStack Spacing="4">

                    @* ── Status ── *@
                    <MudSelect T="EntityStatus"
                               Value="_status"
                               ValueChanged="@((EntityStatus v) => _status = v)"
                               Label="Status"
                               Variant="Variant.Outlined"
                               Disabled="_saving"
                               HelperText="Active allows full use. Disabled blocks all operations. ReceiveDisabled blocks consumers only.">
                        <MudSelectItem Value="EntityStatus.Active">Active</MudSelectItem>
                        <MudSelectItem Value="EntityStatus.Disabled">Disabled</MudSelectItem>
                        <MudSelectItem Value="EntityStatus.ReceiveDisabled">Receive Disabled</MudSelectItem>
                    </MudSelect>

                    <MudDivider />

                    @* ── Numeric settings ── *@
                    <MudNumericField T="int"
                                     @bind-Value="_maxDeliveryCount"
                                     Label="Max Delivery Count"
                                     Variant="Variant.Outlined"
                                     Min="1"
                                     Required="true"
                                     Disabled="_saving"
                                     HelperText="How many times delivery is attempted before the message is dead-lettered." />

                    <MudNumericField T="int"
                                     @bind-Value="_lockDurationSeconds"
                                     Label="Lock Duration (seconds)"
                                     Variant="Variant.Outlined"
                                     Min="1"
                                     Max="300"
                                     Required="true"
                                     Disabled="_saving"
                                     HelperText="How long a received message stays locked (1 – 300 s)." />

                    <MudNumericField T="int"
                                     @bind-Value="_messageTtlSeconds"
                                     Label="Message TTL (seconds)"
                                     Variant="Variant.Outlined"
                                     Min="1"
                                     Max="3600"
                                     Required="true"
                                     Disabled="_saving"
                                     HelperText="How long a message stays in this subscription before expiring (1 – 3 600 s). Emulator limit." />

                    <MudDivider />

                    @* ── Toggles ── *@
                    <MudSwitch T="bool"
                               @bind-Value="_deadLetterOnExpiry"
                               Label="Dead-letter on Message Expiry"
                               Color="Color.Primary"
                               Disabled="_saving" />

                    <MudSwitch T="bool"
                               @bind-Value="_enableBatchedOperations"
                               Label="Enable Batched Operations"
                               Color="Color.Primary"
                               Disabled="_saving" />

                    <MudDivider />

                    @* ── Immutable info ── *@
                    <MudTooltip Text="Requires Session cannot be changed after creation.">
                        <MudChip T="string"
                                 Color="@(_props.RequiresSession ? Color.Tertiary : Color.Default)"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small"
                                 Icon="@Icons.Material.Filled.Lock">
                            Session: @(_props.RequiresSession ? "Required" : "Not required") (immutable)
                        </MudChip>
                    </MudTooltip>

                </MudStack>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Variant="Variant.Text"
                   Disabled="_saving">
            Cancel
        </MudButton>
        <MudButton OnClick="SaveAsync"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@(_saving ? null : Icons.Material.Filled.Save)"
                   ButtonType="ButtonType.Button"
                   Disabled="@(_loading || _saving || !_formValid || _loadError is not null)">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Saving…</span>
            }
            else
            {
                <span>Save</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired] public string TopicName { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string SubscriptionName { get; set; } = string.Empty;

    private MudForm _form = null!;
    private bool _formValid = true;

    private SubscriptionProperties? _props;
    private string? _loadError;
    private bool _loading;
    private bool _saving;

    private EntityStatus _status;
    private int _maxDeliveryCount;
    private int _lockDurationSeconds;
    private int _messageTtlSeconds;
    private bool _deadLetterOnExpiry;
    private bool _enableBatchedOperations;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _props = await TopicService.GetSubscriptionPropertiesAsync(TopicName, SubscriptionName);
            _status = _props.Status;
            _maxDeliveryCount = _props.MaxDeliveryCount;
            _lockDurationSeconds = (int)_props.LockDuration.TotalSeconds;
            _messageTtlSeconds = Math.Clamp((int)_props.DefaultMessageTimeToLive.TotalSeconds, 1, 3600);
            _deadLetterOnExpiry = _props.DeadLetteringOnMessageExpiration;
            _enableBatchedOperations = _props.EnableBatchedOperations;
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load subscription properties: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            await _form.ValidateAsync();
            if (!_formValid) return;

            _props!.Status = _status;
            _props.MaxDeliveryCount = _maxDeliveryCount;
            _props.LockDuration = TimeSpan.FromSeconds(_lockDurationSeconds);
            _props.DefaultMessageTimeToLive = TimeSpan.FromSeconds(_messageTtlSeconds);
            _props.DeadLetteringOnMessageExpiration = _deadLetterOnExpiry;
            _props.EnableBatchedOperations = _enableBatchedOperations;

            await TopicService.UpdateSubscriptionAsync(_props);
            Snackbar.Add($"Subscription \"{SubscriptionName}\" updated successfully.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save subscription: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
